# ── Google AI Studio ───────────────────────────────────
# Get your key at: aistudio.google.com → Get API Key
GOOGLE_API_KEY=your_google_api_key
# Optional: comma-separated fallback list (default tries 2.5-flash, then lite models)
# GEMINI_MODEL=gemini-2.5-flash,gemini-2.5-flash-lite

# ── Database (PostgreSQL) ───────────────────────────────
# Free option: supabase.com → New project → Settings → Database → Connection string
DATABASE_URL=your_database_url

# ── Auth ────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret

# ── Server ──────────────────────────────────────────────
PORT=3001
NODE_ENV=development
